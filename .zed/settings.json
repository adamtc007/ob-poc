{
  "file_types": {
    "DSL": ["dsl", "obl", "onboard", "obdsl"],
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "features": ["database"],
          "noDefaultFeatures": false,
          "buildScripts": {
            "enable": true,
          },
          "unsetTest": ["dsl_types"],
        },
        "check": {
          "command": "clippy",
          "features": ["database"],
          "allTargets": false,
        },
        "procMacro": {
          "enable": true,
        },
      },
    },
  },
  "languages": {
    "DSL": {
      "language_servers": ["dsl-lsp"],
    },
  },
  "inline_completions": {
    "provider": "copilot",
  },
}
