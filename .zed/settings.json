{
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/target",
    "**/dist",
    "artifacts",
    "static/pkg",
    "observatory-wasm/pkg",
    "rust/crates/dsl-lsp/tree-sitter-dsl/node_modules",
    "rust/crates/dsl-lsp/zed-extension/grammars/**/node_modules",
  ],
  "file_types": {
    "DSL": ["dsl", "obl", "onboard", "obdsl"],
  },
  "lsp": {
    "eslint": {
      "settings": {
        "workingDirectories": [
          {
            "directory": "./ob-poc-ui-react",
            "changeProcessCWD": true,
          },
        ],
        "validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact",
        ],
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        // Tell rust-analyzer exactly which workspace roots to analyse.
        // Without this it auto-discovers, which can pick up stale or
        // duplicate roots. The three paths below cover:
        //   rust/       — ob-poc application workspace
        //   ~/dev/dsl/  — dsl library (resolved via [patch] in rust/.cargo/config.toml)
        //   ~/dev/sem-os/ — sem-os library (same [patch] mechanism)
        // bpmn-lite/ has its own Cargo.toml and is auto-discovered separately.
        "linkedProjects": [
          "./rust/Cargo.toml",
          "/Users/adamtc007/dev/dsl/Cargo.toml",
          "/Users/adamtc007/dev/sem-os/Cargo.toml",
        ],
        "cargo": {
          "features": ["database"],
          "noDefaultFeatures": false,
          "buildScripts": {
            "enable": true,
          },
          "targetDir": "/Users/adamtc007/.cargo-target-ra",
        },
        "check": {
          "command": "clippy",
          "features": ["database"],
          "allTargets": false,
        },
        "procMacro": {
          "enable": true,
        },
        "diagnostics": {
          // Suppress "unlinked-file" hints — orphaned files in extracted crate
          // source trees that are no longer workspace members are expected.
          "disabled": ["unlinked-file"],
        },
      },
    },
  },
  "languages": {
    "DSL": {
      "language_servers": ["dsl-lsp"],
    },
    "JavaScript": {
      "language_servers": ["eslint", "vtsls", "!biome", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "language_servers": ["eslint", "vtsls", "!biome", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TSX": {
      "language_servers": ["eslint", "vtsls", "!biome", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
  },
  "inline_completions": {
    "provider": "copilot",
  },
}
