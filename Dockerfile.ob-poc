# syntax=docker/dockerfile:1
#
# Build context: ob-poc/ repository root (one level above rust/)
# Builds the ob-poc-web binary (axum web server + federated bus, T7 stack).
#
# Usage (from ob-poc/):
#   docker build -f Dockerfile.ob-poc -t ob-poc-app:local .
#
# The build needs the full ob-poc workspace (rust/) plus the bpmn-lite
# bus crates (referenced as path deps from rust/crates/).

# ── Stage 1: chef ────────────────────────────────────────────────────
FROM rust:1.95-bookworm AS chef
RUN cargo install cargo-chef --locked
WORKDIR /build

# ── Stage 2: planner ─────────────────────────────────────────────────
FROM chef AS planner
# Copy the full ob-poc workspace including bpmn-lite/ path deps.
COPY rust/ rust/
COPY bpmn-lite/ bpmn-lite/
# ob-poc-web Cargo.toml sits inside rust/ but has path deps to bpmn-lite/.
WORKDIR /build/rust
RUN cargo chef prepare --recipe-path recipe.json -p ob-poc-web

# ── Stage 3: builder ─────────────────────────────────────────────────
FROM chef AS builder
RUN apt-get update \
    && apt-get install -y --no-install-recommends protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

COPY --from=planner /build/rust/recipe.json recipe.json

# Cook dependencies before full copy (Docker layer cache).
COPY bpmn-lite/ /build/bpmn-lite/
WORKDIR /build/rust
RUN cargo chef cook --release -p ob-poc-web --recipe-path recipe.json

COPY rust/ /build/rust/
RUN cargo build --release -p ob-poc-web \
    && strip target/release/ob-poc-web

# ── Stage 4: runtime ─────────────────────────────────────────────────
FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/rust/target/release/ob-poc-web /usr/local/bin/

# Copy ob-poc config (verbs, packs, seeds — required at runtime).
COPY rust/config/ /app/config/

EXPOSE 3000 50061

# Required env: DATABASE_URL
# Optional bus env: OB_POC_BUS_LISTEN (default unset → bus disabled)
#                   BPMN_LITE_BUS_ENDPOINT
#                   OB_POC_CATALOGUE_VERSION (default v1.0.0)
# Optional agent env: AGENT_BACKEND, ANTHROPIC_API_KEY, ANTHROPIC_MODEL
CMD ["ob-poc-web"]
