# Federated DSL platform — environment template (T7)
# Copy to .env and fill in values before running docker compose.

# ── LLM / Sage (ob-poc-app) ─────────────────────────────────────────
# Required for REPL and Sage-mediated workflows.
# The bus demo (§10) works WITHOUT these — leave blank for bus-only demos.
AGENT_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
