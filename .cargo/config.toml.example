# Local-dev [patch] override for the dsl and sem-os library repos.
# Copy this file to .cargo/config.toml (which is git-ignored) when you need
# to edit dsl or sem-os source and have ob-poc pick up changes without a tag bump.
#
# Usage:
#   cp .cargo/config.toml.example .cargo/config.toml
#   # edit ~/dev/dsl or ~/dev/sem-os
#   # changes are picked up automatically by cargo
#
# PRODUCTION (once repos are pushed to GitHub with tags):
# Remove this file. ob-poc crate Cargo.toml files will use git-tag deps.
# Final migration step: change path deps to:
#   dsl_types = { git = "https://github.com/adamtc007/dsl", tag = "v0.1.0" }
#   dsl-core  = { git = "https://github.com/adamtc007/dsl", tag = "v0.1.0" }
#   sem_os_types    = { git = "https://github.com/adamtc007/sem-os", tag = "v0.1.0" }
#   sem_os_core     = { git = "https://github.com/adamtc007/sem-os", tag = "v0.1.0" }
#   sem_os_ontology = { git = "https://github.com/adamtc007/sem-os", tag = "v0.1.0" }
#
# [patch."https://github.com/adamtc007/dsl"]
# dsl_types = { path = "../../dev/dsl/crates/dsl_types" }
# dsl-core  = { path = "../../dev/dsl/crates/dsl-core"  }
#
# [patch."https://github.com/adamtc007/sem-os"]
# sem_os_types    = { path = "../../dev/sem-os/crates/sem_os_types"    }
# sem_os_core     = { path = "../../dev/sem-os/crates/sem_os_core"     }
# sem_os_ontology = { path = "../../dev/sem-os/crates/sem_os_ontology" }
