; Pattern D: transition_args present — see docs/verb-redesigns/
(verb trading-profile.activate
  :description "DEPRECATED — use trading-profile.go-live instead.\n\nLegacy verb that directly transitioned APPROVED → ACTIVE. The pilot\nP.2 lifecycle refactor introduced parallel_run as an explicit state\nbetween approved and active: APPROVED → PARALLEL_RUN → ACTIVE via\nenter-parallel-run + go-live respectively.\n\nRetained for backward compatibility with the existing\nactivate_trading_profile handler; new code should route through\ntrading-profile.enter-parallel-run → trading-profile.go-live.\n\nTier tightened to match go-live: requires_explicit_authorisation\n(live mandate activation has same blast radius regardless of path).\n"
  :behavior "plugin"
  :handler "activate_trading_profile"
  :effect-class "admin_override"
  :flavour "discretionary"
  :role-guard "{\"any_of\":[\"compliance_admin\",\"senior_compliance\",\"mlro\"]}"
  :audit-class "trading_profile_activate"
  :metadata-json "{\"tier\":\"intent\",\"source_of_truth\":\"matrix\",\"scope\":\"cbu\",\"writes_operational\":false,\"side_effects\":\"state_write\",\"harm_class\":null,\"action_class\":null,\"noun\":\"trading_matrix\",\"internal\":false,\"tags\":[\"lifecycle\",\"activation\",\"deprecated\"],\"replaces\":null,\"status\":\"deprecated\",\"replaced_by\":\"trading-profile.go-live\",\"since_version\":\"0.1\",\"removal_version\":\"1.0\",\"dangerous\":false,\"subject_kinds\":[],\"phase_tags\":[\"trading\"],\"requires_subject\":true,\"produces_focus\":false}"
  :three-axis-json "{\"state_effect\":\"transition\",\"external_effects\":[\"emitting\"],\"consequence\":{\"baseline\":\"requires_explicit_authorisation\",\"escalation\":[]}}"
  :transition-args-json "{\"entity_id_arg\":\"profile-id\",\"target_workspace\":\"instrument_matrix\",\"target_slot\":\"trading_profile\"}"
  :returns-json "{\"type\":\"record\",\"name\":null,\"capture\":null}"
