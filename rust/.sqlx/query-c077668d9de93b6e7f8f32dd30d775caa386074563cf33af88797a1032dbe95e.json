  "query": "\n            SELECT\n                case_id as id,\n                status,\n                case_type,\n                risk_rating,\n                opened_at\n            FROM \"ob-poc\".cases\n            WHERE cbu_id = $1\n              AND status NOT IN ('APPROVED', 'REJECTED', 'WITHDRAWN')\n            ORDER BY opened_at DESC\n            ",
