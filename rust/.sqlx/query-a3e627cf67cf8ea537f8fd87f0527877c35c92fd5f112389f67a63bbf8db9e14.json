  "query": "\n            SELECT\n                e.entity_id as \"entity_id!: Uuid\",\n                pp.nationality,\n                pp.date_of_birth,\n                e.created_at,\n                e.updated_at\n            FROM \"ob-poc\".entities e\n            LEFT JOIN \"ob-poc\".entity_proper_persons pp ON e.entity_id = pp.entity_id\n            WHERE e.entity_id = ANY($1)\n            ",
