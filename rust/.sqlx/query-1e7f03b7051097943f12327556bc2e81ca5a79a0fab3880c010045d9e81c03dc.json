  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                request_id,\n                request_type,\n                request_subtype,\n                requested_from_label,\n                requested_at,\n                due_date,\n                reminder_count,\n                escalation_level,\n                status,\n                blocker_message,\n                CURRENT_DATE - due_date as days_overdue\n            FROM \"ob-poc\".outstanding_requests\n            WHERE workstream_id = $1 AND status IN ('PENDING', 'ESCALATED')\n            ORDER BY due_date ASC\n            ",
