{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            c.case_id,\n            c.status,\n            c.risk_rating,\n            c.case_type,\n            c.escalation_level,\n            c.opened_at,\n            c.sla_deadline,\n            c.notes,\n            cb.cbu_id,\n            cb.name as cbu_name,\n            cb.client_type\n        FROM \"ob-poc\".cases c\n        JOIN \"ob-poc\".cbus cb ON c.cbu_id = cb.cbu_id\n        WHERE c.case_id = $1\n          AND cb.deleted_at IS NULL\n        ",
