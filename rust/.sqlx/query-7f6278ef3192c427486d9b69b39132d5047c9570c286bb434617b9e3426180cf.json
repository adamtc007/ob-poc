  "query": "\n            SELECT\n                e.entity_id as \"entity_id!: Uuid\",\n                lc.jurisdiction,\n                lc.registration_number,\n                e.created_at,\n                e.updated_at\n            FROM \"ob-poc\".entities e\n            LEFT JOIN \"ob-poc\".entity_limited_companies lc ON e.entity_id = lc.entity_id\n            WHERE e.entity_id = ANY($1)\n            ",
