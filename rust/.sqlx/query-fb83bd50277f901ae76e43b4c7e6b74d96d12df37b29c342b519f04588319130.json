  "query": "\n            SELECT\n                c.cbu_id as \"cbu_id!: Uuid\",\n                c.jurisdiction,\n                c.client_type,\n                c.created_at,\n                c.updated_at,\n                (SELECT COUNT(*) FROM \"ob-poc\".cbu_entity_roles cer WHERE cer.cbu_id = c.cbu_id)::int as role_count\n            FROM \"ob-poc\".cbus c\n            WHERE c.cbu_id = ANY($1)\n            ",
