+        if msg.contains("across") || msg.contains("compare") {
+            return Self::Across;
+        }
+        if msg.contains("that ") || msg.contains("there") || msg.contains("other workspace") {
+            return Self::There;
+        }
+        if msg.contains("this ") || msg.contains("current") || msg.contains("here") {
+            return Self::Here;
+        }
+        Self::Unspecified
+    }
+}
